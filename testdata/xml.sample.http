### Echo XML

@pre-request {%
  set("to", fake.name());
%}

POST https://echo.free.beeceptor.com
Content-Type: application/xml

<note>
  <to>{{to}}</to>
  <from>Me</from>
  <heading>Reminder</heading>
  <body>${{fake.paragraph()}}</body>
</note>

@post-response {%
  test("Status is 200", () => {
    assert(response.status === 200, "expected 200");
  });

  const body = xml.parse(response.json().parsedBody);
  log(body.findAll("body")[0].text);
%}
